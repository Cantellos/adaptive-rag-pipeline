# ── Virtual environment ──────────────────────────────────────────────────────
.venv/

# ── Secrets / environment variables ─────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Build / packaging ─────────────────────────────────────────────────────────
*.egg-info/
dist/
build/
uv.lock

# ── User credentials and chat histories (runtime data, never commit) ─────────
chat_history/
users.json

# ── BM25 reverse index (rebuilt at runtime by the ingestion pipeline) ─────────
reverse_index/

# ── Evaluation artefacts (per-run results, generated by evaluation_pipeline.py)
evaluation_results/

# ── Dataset files (replace gold_dataset.json with your own domain-specific one)
main/evaluation/gold_dataset.json

# ── Document template (replace with your own domain template if needed) ──────
main/evaluation/Sample_RI.docx
main/evaluation/sample_template.docx

# ── RAGAS test sets (generated at runtime) ───────────────────────────────────
testset_ragas.json

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db

# ── Cowork / Claude project instructions (local tool metadata, not for public repo)
CLAUDE.md

# Development backup files (superseded by main/llm/ and main/evaluation/)
main/BACKUP/
