# ============================================================
# .env.example — copy to .env and fill in your values
# ============================================================
# NEVER commit .env to version control.
# This file is safe to commit — it contains only placeholder values.
# ============================================================


# ── Database (SQL Server) ────────────────────────────────────
# Required when config.yaml → input.mode = "database"
# Also required in both modes for storing/querying chunks
DB_SERVER=localhost
DB_NAME=RAGDatabase
DB_UID=sa
DB_PASSWORD=your_password_here


# ── OpenAI / Azure OpenAI ────────────────────────────────────
# Your OpenAI API key (works for both standard OpenAI and Azure OpenAI)
OPENAI_API_KEY=your_api_key_here

# ── Embedding model ──────────────────────────────────────────
# Model used to embed document chunks and user queries.
# Standard OpenAI example:
EMBEDDING_MODEL_1=text-embedding-ada-002
# Leave EMBEDDING_URL_1 / EMBEDDING_VERSION_1 empty for standard OpenAI.
# Fill them in only if you use Azure OpenAI:
EMBEDDING_URL_1=
EMBEDDING_VERSION_1=

# Second (optional) embedding model — used in ablation studies only
EMBEDDING_MODEL_2=text-embedding-3-large
EMBEDDING_URL_2=
EMBEDDING_VERSION_2=


# ── LLM model (chatbot + pipeline steps) ─────────────────────
LLM_MODEL=gpt-4o

# Leave LLM_URL and LLM_VERSION empty to use standard api.openai.com.
# Fill them in only for Azure OpenAI deployments:
LLM_URL=
LLM_VERSION=

# Optional: custom base URL for OpenAI-compatible endpoints (e.g. LM Studio, Ollama)
# LLM_BASE_URL=http://localhost:1234/v1


# ── Judge model (evaluation pipeline) ────────────────────────
# Model used as LLM-as-judge in evaluation_pipeline.py.
# Defaults to the same model/endpoint as LLM_MODEL if not set.
JUDGE_MODEL=gpt-4o
JUDGE_URL=
JUDGE_VERSION=


# ── Evaluation ───────────────────────────────────────────────
# Absolute or relative path to the gold dataset JSON file.
# Defaults to main/evaluation/gold_dataset.json if not set.
# GOLD_DATASET_PATH=main/evaluation/gold_dataset.json
